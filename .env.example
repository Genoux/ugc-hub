# UGC Hub — copy to .env.local and fill in values.
# Vercel: use Production, Preview, and Development only.
# Ensure DATABASE_URL is set for Production, Preview, and Development

# -----------------------------------------------------------------------------
# Database (Neon)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# -----------------------------------------------------------------------------
# Auth (Clerk)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
ALLOWED_DOMAIN=your-domain.com

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ugc-hub

# -----------------------------------------------------------------------------
# Integrations (optional)
# -----------------------------------------------------------------------------
# Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
